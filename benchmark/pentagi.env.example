# PentAGI is the solver. The benchmark harness remains the private evaluator.
PENTAGI_BASE_URL=https://127.0.0.1:8443
PENTAGI_PROVIDER=deepseek
PENTAGI_API_TOKEN=

# The current local PentAGI deployment uses a self-signed certificate.
# Prefer a CA bundle path when one is available. Use false only for this
# loopback-only benchmark deployment.
PENTAGI_TLS_VERIFY=false
