# Copy this file to .env in the repository root. Never commit the real .env.
SECMIND_IMAGE_TAG=local
SECMIND_FRONTEND_BIND=127.0.0.1
SECMIND_FRONTEND_PORT=5173
SECMIND_BACKEND_BIND=127.0.0.1
SECMIND_BACKEND_PORT=8000

POSTGRES_DB=secmind
POSTGRES_USER=secmind
POSTGRES_PASSWORD=replace_with_a_long_url_safe_password
SECMIND_DATABASE_URL=postgresql+psycopg://secmind:replace_with_a_long_url_safe_password@postgres:5432/secmind
SECMIND_CHECKPOINT_BACKEND=postgres
SECMIND_CHECKPOINT_DATABASE_URL=postgresql+psycopg://secmind:replace_with_a_long_url_safe_password@postgres:5432/secmind
SECMIND_PROJECTION_ENABLED=true
SECMIND_RUNTIME_MAX_RUNTIME_SECONDS=600
SECMIND_RUNTIME_SIMPLE_MAX_SECONDS=120
SECMIND_RUNTIME_SIMPLE_MAX_AGENTS=6
SECMIND_RUNTIME_STANDARD_MAX_SECONDS=300
SECMIND_RUNTIME_STANDARD_MAX_AGENTS=12
SECMIND_RUNTIME_COMPLEX_MAX_SECONDS=600
SECMIND_RUNTIME_COMPLEX_MAX_AGENTS=20
SECMIND_RUNTIME_SOFT_DEADLINE_RATIO=0.7
SECMIND_RUNTIME_TOOL_GRACE_DEADLINE_RATIO=0.9
SECMIND_GRAPHQL_PATH=/graphql
SECMIND_GRAPHQL_SUBSCRIPTION_KEEPALIVE_SECONDS=20
SECMIND_AGENT_MAX_PARALLEL=8
SECMIND_AGENT_MAX_DELEGATION_DEPTH=12
SECMIND_MCP_CONNECT_TIMEOUT_SECONDS=30
SECMIND_MCP_CALL_TIMEOUT_SECONDS=300
SECMIND_MCP_REFRESH_INTERVAL_SECONDS=60
SECMIND_PROMPT_AUTO_RELOAD=false

SECMIND_LLM_PROVIDER=qwen
SECMIND_LLM_API_KEY=
SECMIND_LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
SECMIND_LLM_MODEL=qwen-plus
SECMIND_LLM_PLANNER_MODEL=qwen-plus
SECMIND_LLM_WORKER_MODEL=qwen-turbo
SECMIND_LLM_FALLBACK_MODEL=qwen-max
SECMIND_LLM_EMBEDDING_MODEL=text-embedding-v3
SECMIND_LLM_THINKING_ENABLED=true
SECMIND_LLM_REASONING_EFFORT=max
SECMIND_LLM_PRIMARY_THINKING_ENABLED=false
SECMIND_LLM_PLAN_THINKING_ENABLED=false
SECMIND_LLM_ANALYZE_THINKING_ENABLED=false
SECMIND_LLM_VERIFY_THINKING_ENABLED=false
SECMIND_LLM_REPORT_THINKING_ENABLED=false
SECMIND_LLM_MAX_SINGLE_PROMPT_TOKENS=32000
SECMIND_LLM_MAX_RUN_PROMPT_TOKENS=100000

# Enable only after SECMIND_LLM_API_KEY is configured for embeddings.
SECMIND_QDRANT_ENABLED=false
SECMIND_QDRANT_COLLECTION=secmind_knowledge
SECMIND_QDRANT_MEMORY_COLLECTION=secmind_memory
SECMIND_QDRANT_VECTOR_SIZE=1024

SECMIND_API_KEY=
SECMIND_CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
VITE_API_BASE_URL=/
VITE_WS_BASE_URL=/
