      "url": "http://host.docker.internal:9013/mcp",
      "enabled": true,
      "metadata": {"node": "local", "category": "security"}
    },
    {
      "schema_version": "1.0",
      "server_id": "local-cyberchef",
      "name": "Local CyberChef",
      "transport": "streamable_http",
      "url": "http://host.docker.internal:9014/mcp",
      "enabled": true,
