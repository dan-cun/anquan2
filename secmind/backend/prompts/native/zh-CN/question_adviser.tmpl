<question_adviser_context>
  <instruction>根据用户的问题，利用提供的上下文和工具，生成全面且详细的建议。</instruction>

  <initiator_agent>{{.InitiatorAgent}}</initiator_agent>

  {{if .Enriches}}
  <enrichment_data>
  {{.Enriches}}
  </enrichment_data>
  {{end}}

  <user_question>
  {{.Question}}
  </user_question>

  {{if .Code}}
  <code_snippet>
  {{.Code}}
  </code_snippet>
  {{end}}

  {{if .Output}}
  <command_output>
  {{.Output}}
  </command_output>
  {{end}}
</question_adviser_context>