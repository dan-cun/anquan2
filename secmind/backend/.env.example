SECMIND_APP_ENV=development
SECMIND_API_KEY=
SECMIND_API_KEY_FILE=
SECMIND_LOG_LEVEL=INFO
SECMIND_RATE_LIMIT_ENABLED=true
SECMIND_RATE_LIMIT_REQUESTS=120
SECMIND_RATE_LIMIT_WINDOW_SECONDS=60
SECMIND_DATA_DIR=./data
SECMIND_LEDGER_DIR=./data/ledger
SECMIND_CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
SECMIND_LEDGER_SNAPSHOT_INTERVAL=10
SECMIND_MOCK_STEP_DELAY_SECONDS=0.02
# Canonical SQL database for runtime events, projections, and run summaries.
SECMIND_DATABASE_URL=sqlite:///./data/runtime/secmind.db
SECMIND_DATABASE_ECHO=false
SECMIND_DATABASE_POOL_SIZE=5
SECMIND_RUNTIME_INPUT_ROOT=./data/inputs
SECMIND_RUNTIME_RUN_ROOT=./data/runs
SECMIND_RUNTIME_UPLOAD_ROOT=./data/uploads
SECMIND_RUNTIME_DEMO_MODE=true
SECMIND_RUNTIME_MAX_STEPS=12
SECMIND_RUNTIME_MAX_TOOL_CALLS=12
SECMIND_RUNTIME_MAX_MODEL_CALLS=20
SECMIND_RUNTIME_MAX_RUNTIME_SECONDS=600
SECMIND_RUNTIME_MAX_UPLOAD_BYTES=52428800
SECMIND_RUNTIME_MAX_EXTRACTED_BYTES=209715200
SECMIND_RUNTIME_MAX_FILES=10000
SECMIND_RUNTIME_MAX_ZIP_RATIO=100

# LangGraph persistence. Use postgres in Docker Compose.
SECMIND_CHECKPOINT_BACKEND=memory
SECMIND_CHECKPOINT_DATABASE_URL=
SECMIND_CHECKPOINT_NAMESPACE=secmind

# Event projections are disabled until the projection worker is installed.
SECMIND_PROJECTION_ENABLED=false
SECMIND_PROJECTION_BATCH_SIZE=500
SECMIND_PROJECTION_REBUILD_ON_START=false

# Qwen / OpenAI-compatible LLM configuration.
# Fill SECMIND_LLM_API_KEY locally. Do not commit real keys.
SECMIND_LLM_PROVIDER=qwen
SECMIND_LLM_API_KEY=
SECMIND_LLM_API_KEY_FILE=
SECMIND_LLM_BASE_URL=https://ws-6a97xnb0sh5clxp6.cn-beijing.maas.aliyuncs.com/compatible-mode/v1
SECMIND_LLM_MODEL=qwen-plus
SECMIND_LLM_PLANNER_MODEL=
SECMIND_LLM_WORKER_MODEL=
SECMIND_LLM_FALLBACK_MODEL=
SECMIND_LLM_EMBEDDING_MODEL=text-embedding-v3
SECMIND_LLM_TIMEOUT_SECONDS=60
SECMIND_LLM_TEMPERATURE=0.2

# Qdrant is optional for local development and enabled by Compose when available.
SECMIND_QDRANT_ENABLED=false
SECMIND_QDRANT_URL=http://127.0.0.1:6333
SECMIND_QDRANT_API_KEY=
SECMIND_QDRANT_API_KEY_FILE=
SECMIND_QDRANT_COLLECTION=secmind_knowledge
SECMIND_QDRANT_MEMORY_COLLECTION=secmind_memory
SECMIND_QDRANT_VECTOR_SIZE=1024
SECMIND_QDRANT_TIMEOUT_SECONDS=10
