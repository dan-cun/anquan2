SECMIND_APP_ENV=development
SECMIND_LOG_LEVEL=INFO
SECMIND_DATA_DIR=./data
SECMIND_LEDGER_DIR=./data/ledger
SECMIND_CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
SECMIND_LEDGER_SNAPSHOT_INTERVAL=10
SECMIND_MOCK_STEP_DELAY_SECONDS=0.02

# Qwen / OpenAI-compatible LLM configuration.
# Fill SECMIND_LLM_API_KEY locally. Do not commit real keys.
SECMIND_LLM_PROVIDER=qwen
SECMIND_LLM_API_KEY=
SECMIND_LLM_BASE_URL=https://ws-6a97xnb0sh5clxp6.cn-beijing.maas.aliyuncs.com/compatible-mode/v1
SECMIND_LLM_MODEL=qwen-plus
SECMIND_LLM_TIMEOUT_SECONDS=60
SECMIND_LLM_TEMPERATURE=0.2
